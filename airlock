#!/usr/bin/env bash
# airlock — a disposable, hardened Linux sandbox for running untrusted code and
# deploying with throwaway CLI logins. Two modes:
#
#   airlock run [CMD]   UNTRUSTED mode: no host secrets, locked-down, egress
#                       only through a domain whitelist proxy. For OSS you don't
#                       trust. (alias: `airlock shell`)
#   airlock dev [CMD]   TRUSTED mode: your Claude login works, full internet.
#                       For your own code.
#
#   airlock exec [CMD]  open ANOTHER terminal into the running sandbox
#   airlock allow DOM   add a domain to the egress whitelist (then rebuild)
#   airlock down        stop & remove sandbox + proxy containers
#   airlock status      show images, running containers, whitelist
#   airlock build       (re)build the images
#   airlock rebuild     rebuild from scratch (no cache)
#   airlock logs        follow proxy logs (see what egress is allowed/blocked)
#   airlock help        this help   (also: --help, -h)
#
# run/dev are throwaway (--rm): each spin is fresh. Ports 3000/3001/5173/4000/8080
# are published to the host so dev servers are reachable (bind to 0.0.0.0!).
set -euo pipefail

# Directory you invoked airlock from -> becomes /workspace. Capture before cd.
INVOKE_DIR="$PWD"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

SANDBOX_IMAGE="syedtasavour/airlock-sandbox:latest"
PROXY_IMAGE="syedtasavour/airlock-proxy:latest"
FILTER="$DIR/proxy/filter"

# Colors (disabled when output isn't a terminal, e.g. piped).
if [ -t 1 ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; G=$'\033[32m'; Y=$'\033[33m'
  C=$'\033[36m'; R=$'\033[31m'; N=$'\033[0m'
else
  B=""; DIM=""; G=""; Y=""; C=""; R=""; N=""
fi
hr() { printf '  %s\n' "${DIM}────────────────────────────────────────────────────${N}"; }

# Turn the proxy regex filter into human-readable domains:
#   \.npmjs\.org$ -> *.npmjs.org      ^github\.com$ -> github.com
readable_whitelist() {
  grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$FILTER" 2>/dev/null \
    | sed -E 's/\$$//; s/^\^//; s/^\\\./*./; s/\\\././g' | sort -u
}

dc() { docker compose "$@"; }
image_exists() { docker image inspect "$1" >/dev/null 2>&1; }

ensure_built() {
  if ! image_exists "$SANDBOX_IMAGE"; then
    echo "› images not found — building (first time only)…"
    dc --profile run --profile dev build
  fi
}

# Mount the dir you ran airlock from as /workspace. Refuse overly-broad roots.
set_workspace() {
  if [ "$INVOKE_DIR" = "$HOME" ] || [ "$INVOKE_DIR" = "/" ]; then
    echo "${R}✗ refusing to mount '$INVOKE_DIR' (too broad). cd into a project first.${N}"
    exit 1
  fi
  export WORKSPACE="$INVOKE_DIR"
}

# Export Claude login from the macOS Keychain into a local read-only file so the
# sandbox can reuse it. Only ever read by the container; refreshes stay inside.
# Sets CLAUDE_STATE (a colored summary) for the launch banner.
CLAUDE_STATE=""
sync_claude_creds() {
  local secrets="$DIR/.secrets" file
  file="$secrets/.credentials.json"
  mkdir -p "$secrets"; chmod 700 "$secrets"
  if security find-generic-password -s "Claude Code-credentials" -w \
       > "$file" 2>/dev/null && [ -s "$file" ]; then
    chmod 600 "$file"
    CLAUDE_STATE="${G}logged in${N} ${DIM}(synced from your Keychain)${N}"
  else
    : > "$file"
    CLAUDE_STATE="${Y}not logged in${N} ${DIM}(run /login inside, or set ANTHROPIC_API_KEY)${N}"
  fi
}

# Polished launch banner. Adapts to terminal: colored on a TTY, plain when piped.
# $1 = mode (run|dev)
launch_banner() {
  local mode="$1" wl
  wl="$(readable_whitelist | wc -l | tr -d ' ')"
  echo ""
  hr
  if [ "$mode" = run ]; then
    echo "  🔒 ${B}${G}airlock · UNTRUSTED${N}   ${DIM}safe — locked-down sandbox${N}"
  else
    echo "  ⚠  ${B}${Y}airlock · DEV${N}   ${DIM}trusted — full access, for your own code${N}"
  fi
  hr
  echo "  ${B}path${N}      ${C}${WORKSPACE}${N}"
  echo "            ${DIM}↳ mounted at /workspace — the only host folder the box can see${N}"
  if [ "$mode" = run ]; then
    echo "  ${B}network${N}   ${G}whitelist only${N} ${DIM}· ${wl} domains allowed, everything else blocked${N}"
    echo "  ${B}secrets${N}   ${G}none of your files${N} ${DIM}· Claude token only, no history${N}"
  else
    echo "  ${B}network${N}   ${Y}full internet${N}"
    echo "  ${B}secrets${N}   ${Y}Claude login + history${N} ${DIM}· trusted mode${N}"
  fi
  echo "  ${B}ports${N}     ${DIM}3000 3001 5173 4000 8080 → http://localhost:<port> on your Mac${N}"
  echo "  ${B}claude${N}    ${CLAUDE_STATE}"
  hr
  echo "  ${DIM}type 'exit' to leave — the container is destroyed (fresh next spin)${N}"
  echo ""
}

# Find the running sandbox container (untrusted or dev), excluding the proxy.
running_sandbox() {
  docker ps --format '{{.ID}} {{.Names}}' \
    | grep -E 'airlock-(untrusted|dev)-run' | awk '{print $1}' | head -1
}

print_help() {
  cat <<EOF
  ${B}airlock${N} — disposable hardened sandbox for running untrusted code & deploying

  ${B}USAGE${N}
    airlock <command> [args]

  ${B}ENTER A SANDBOX${N}
    ${G}run${N} [cmd]        🔒 untrusted code — no history, whitelist-only network
    ${Y}dev${N} [cmd]        ⚠  your own code — Claude login + full internet
    exec [cmd]       open another terminal into the running sandbox

  ${B}NETWORK${N}
    allow <domain>   permit a domain in 'run' mode, then run: airlock rebuild
    logs             watch what the proxy allows / blocks

  ${B}MANAGE${N}
    status           what's running, and whether it's safe
    down             stop & remove the sandbox + proxy
    build            build images
    rebuild          build images from scratch (no cache)

  ${B}INFO${N}
    help             this help   (also: --help, -h)

  ${B}EXAMPLES${N}
    ${DIM}cd ~/some/oss && airlock run${N}        run sketchy code safely
    ${DIM}cd ~/CodeBase/app && airlock dev${N}    your code, with Claude
    ${DIM}airlock run npm test${N}                one-off command
    ${DIM}airlock allow files.example.com${N}     widen the whitelist

  ${DIM}The folder you launch from becomes /workspace — the only host folder the
  sandbox sees. Bind dev servers to 0.0.0.0 to reach them at localhost on your Mac.${N}
EOF
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  run|shell)
    ensure_built
    set_workspace
    sync_claude_creds
    launch_banner run
    if [ "$#" -eq 0 ]; then
      dc --profile run run --rm --service-ports untrusted bash
    else
      dc --profile run run --rm --service-ports untrusted "$@"
    fi
    ;;

  dev)
    ensure_built
    set_workspace
    sync_claude_creds
    launch_banner dev
    if [ "$#" -eq 0 ]; then
      dc --profile dev run --rm --service-ports dev bash
    else
      dc --profile dev run --rm --service-ports dev "$@"
    fi
    ;;

  exec)
    cid="$(running_sandbox || true)"
    if [ -z "${cid:-}" ]; then
      echo "✗ no running sandbox — start one first: airlock run   (or: airlock dev)"
      exit 1
    fi
    echo "› attaching to running sandbox $cid"
    if [ "$#" -eq 0 ]; then docker exec -it "$cid" bash; else docker exec -it "$cid" "$@"; fi
    ;;

  allow)
    [ "$#" -ge 1 ] || { echo "usage: airlock allow <domain>   e.g. airlock allow example.com"; exit 1; }
    dom="$1"
    # Escape dots, anchor to end-of-host so subdomains of it match.
    printf '\\.%s$\n' "$(echo "$dom" | sed 's/^\*\.//; s/\./\\./g')" >> "$FILTER"
    echo "› added '$dom' to whitelist. Rebuild to apply:  airlock rebuild"
    ;;

  down)
    echo "› stopping sandbox + proxy…"
    dc --profile run --profile dev down --remove-orphans >/dev/null 2>&1 || true
    docker ps -a --format '{{.ID}} {{.Names}}' \
      | grep -E 'airlock-(untrusted|dev)-run' | awk '{print $1}' \
      | xargs -r docker rm -f >/dev/null 2>&1 || true
    echo "› done"
    ;;

  status)
    echo ""
    hr; echo "  ${B}airlock — status${N}"; hr
    echo ""

    # ---- images ----
    echo "  ${B}Images${N}"
    if image_exists "$SANDBOX_IMAGE"; then echo "    ${G}✓${N} sandbox   ${DIM}${SANDBOX_IMAGE}${N}"
    else echo "    ${R}✗${N} sandbox   ${DIM}${SANDBOX_IMAGE}${N}   ${Y}→ run: airlock build${N}"; fi
    if image_exists "$PROXY_IMAGE"; then echo "    ${G}✓${N} proxy     ${DIM}${PROXY_IMAGE}${N}"
    else echo "    ${R}✗${N} proxy     ${DIM}${PROXY_IMAGE}${N}   ${Y}→ run: airlock build${N}"; fi
    echo ""

    # ---- running ----
    echo "  ${B}Running now${N}"
    found=0
    while IFS=$'\t' read -r name st; do
      [ -z "$name" ] && continue
      found=1
      case "$name" in
        *untrusted*) echo "    🔒 ${G}SAFE${N}     ${name}  ${DIM}· untrusted · whitelist net · ${st}${N}" ;;
        *dev*)       echo "    ⚠  ${Y}TRUSTED${N}  ${name}  ${DIM}· full internet + history · ${st}${N}" ;;
        *proxy*)     echo "    🛡  ${C}proxy${N}    ${name}  ${DIM}· egress whitelist · ${st}${N}" ;;
        *)           echo "    • ${name}  ${DIM}· ${st}${N}" ;;
      esac
    done < <(docker ps --filter "name=airlock" --format '{{.Names}}\t{{.Status}}')
    [ "$found" = 0 ] && echo "    ${DIM}nothing running — sandboxes are disposable, this is normal${N}"
    echo ""

    # ---- modes ----
    echo "  ${B}Modes${N}"
    echo "    ${G}airlock run${N}   🔒 ${G}safe${N}     ${DIM}untrusted code · whitelist network · no history${N}"
    echo "    ${Y}airlock dev${N}   ⚠  ${Y}trusted${N}  ${DIM}your code · full internet · Claude history${N}"
    echo ""

    # ---- whitelist (readable) ----
    wl_count="$(readable_whitelist | wc -l | tr -d ' ')"
    echo "  ${B}Network whitelist${N}  ${DIM}· ${wl_count} domains reachable in 'run' mode; all others blocked${N}"
    printf '%s' "$C"
    readable_whitelist | awk '{printf "    %-26s", $0; if (NR%2==0) printf "\n"} END {if (NR%2) printf "\n"}'
    printf '%s' "$N"
    echo "    ${DIM}edit: airlock allow <domain>   ·   list lives in proxy/filter${N}"
    hr
    ;;

  build)   dc --profile run --profile dev build "$@" ;;
  rebuild) dc --profile run --profile dev build --no-cache "$@" ;;
  logs)    docker logs -f airlock-proxy ;;

  help|-h|--help) print_help ;;
  *) echo "unknown command: $cmd"; echo "try: airlock --help"; exit 1 ;;
esac
