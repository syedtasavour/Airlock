#!/usr/bin/env bash
# airlock — a disposable, hardened Linux sandbox for running untrusted code and
# deploying with throwaway CLI logins. Two modes:
#
#   airlock run [CMD]   UNTRUSTED mode: no host secrets, locked-down, egress
#                       only through a domain whitelist proxy. For OSS you don't
#                       trust. (alias: `airlock shell`)
#   airlock dev [CMD]   TRUSTED mode: your Claude login works, full internet.
#                       For your own code.
#   airlock sbx [CMD]   STRONGEST mode: a Docker microVM (own kernel) running the
#                       project with airlock's same egress whitelist. Escape-proof
#                       + exfil-proof. Needs `docker sandbox` (Docker Desktop 4.58+).
#                       KEPT & reused by default so login/installs persist:
#                         airlock sbx --fresh   delete the old box, start a new one
#                         airlock sbx down      destroy this project's microVM
#
#   airlock exec [CMD]  open ANOTHER terminal into the running sandbox
#   airlock allow DOM   add a domain to the egress whitelist (then rebuild)
#   airlock down        stop & remove sandbox + proxy containers
#   airlock status      show images, running containers, whitelist
#   airlock build       (re)build the images
#   airlock rebuild     rebuild from scratch (no cache)
#   airlock logs        follow proxy logs (see what egress is allowed/blocked)
#   airlock help        this help   (also: --help, -h)
#
# run/dev are throwaway (--rm): each spin is fresh. Ports 3000/3001/5173/4000/8080
# are published to the host so dev servers are reachable (bind to 0.0.0.0!).
set -euo pipefail

# Directory you invoked airlock from -> becomes /workspace. Capture before cd.
INVOKE_DIR="$PWD"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

SANDBOX_IMAGE="syedtasavour/airlock-sandbox:latest"
PROXY_IMAGE="syedtasavour/airlock-proxy:latest"
FILTER="$DIR/proxy/filter"

# Colors (disabled when output isn't a terminal, e.g. piped).
if [ -t 1 ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; G=$'\033[32m'; Y=$'\033[33m'
  C=$'\033[36m'; R=$'\033[31m'; N=$'\033[0m'
else
  B=""; DIM=""; G=""; Y=""; C=""; R=""; N=""
fi
hr() { printf '  %s\n' "${DIM}────────────────────────────────────────────────────${N}"; }

# Turn the proxy regex filter into human-readable domains:
#   \.npmjs\.org$ -> *.npmjs.org      ^github\.com$ -> github.com
readable_whitelist() {
  grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$FILTER" 2>/dev/null \
    | sed -E 's/\$$//; s/^\^//; s/^\\\./*./; s/\\\././g' | sort -u
}

dc() { docker compose "$@"; }
image_exists() { docker image inspect "$1" >/dev/null 2>&1; }

ensure_built() {
  if ! image_exists "$SANDBOX_IMAGE"; then
    echo "› images not found — building (first time only)…"
    dc --profile run --profile dev build
  fi
}

# Mount the dir you ran airlock from as /workspace. Refuse overly-broad roots.
set_workspace() {
  if [ "$INVOKE_DIR" = "$HOME" ] || [ "$INVOKE_DIR" = "/" ]; then
    echo "${R}✗ refusing to mount '$INVOKE_DIR' (too broad). cd into a project first.${N}"
    exit 1
  fi
  export WORKSPACE="$INVOKE_DIR"
}

# Export Claude login from the macOS Keychain into a local read-only file so the
# sandbox can reuse it. Only ever read by the container; refreshes stay inside.
# Sets CLAUDE_STATE (a colored summary) for the launch banner.
CLAUDE_STATE=""
sync_claude_creds() {
  local secrets="$DIR/.secrets" file
  file="$secrets/.credentials.json"
  mkdir -p "$secrets"; chmod 700 "$secrets"
  if security find-generic-password -s "Claude Code-credentials" -w \
       > "$file" 2>/dev/null && [ -s "$file" ]; then
    chmod 600 "$file"
    CLAUDE_STATE="${G}logged in${N} ${DIM}(synced from your Keychain)${N}"
  else
    : > "$file"
    CLAUDE_STATE="${Y}not logged in${N} ${DIM}(run /login inside, or set ANTHROPIC_API_KEY)${N}"
  fi
}

# Polished launch banner. Adapts to terminal: colored on a TTY, plain when piped.
# $1 = mode (run|dev)
launch_banner() {
  local mode="$1" wl
  wl="$(readable_whitelist | wc -l | tr -d ' ')"
  echo ""
  hr
  if [ "$mode" = run ]; then
    echo "  🔒 ${B}${G}airlock · UNTRUSTED${N}   ${DIM}safe — locked-down sandbox${N}"
  elif [ "$mode" = sbx ]; then
    echo "  🧊 ${B}${C}airlock · SBX${N}   ${DIM}strongest — microVM (own kernel) + whitelist${N}"
  else
    echo "  ⚠  ${B}${Y}airlock · DEV${N}   ${DIM}trusted — full access, for your own code${N}"
  fi
  hr
  echo "  ${B}path${N}      ${C}${WORKSPACE}${N}"
  if [ "$mode" = sbx ]; then
    echo "            ${DIM}↳ mounted in the microVM — the only host folder it can see${N}"
    echo "  ${B}isolation${N} ${C}microVM${N} ${DIM}· own Linux kernel — a container escape can't reach your Mac${N}"
    echo "  ${B}network${N}   ${G}whitelist only${N} ${DIM}· ${wl} domains allowed, everything else blocked${N}"
    echo "  ${B}secrets${N}   ${G}none of your files${N} ${DIM}· project dir only${N}"
    echo "  ${B}ports${N}     ${DIM}publish with: docker sandbox network proxy / ports${N}"
  else
    echo "            ${DIM}↳ mounted at /workspace — the only host folder the box can see${N}"
    if [ "$mode" = run ]; then
      echo "  ${B}network${N}   ${G}whitelist only${N} ${DIM}· ${wl} domains allowed, everything else blocked${N}"
      echo "  ${B}secrets${N}   ${G}none of your files${N} ${DIM}· Claude token only, no history${N}"
    else
      echo "  ${B}network${N}   ${Y}full internet${N}"
      echo "  ${B}secrets${N}   ${Y}Claude login + history${N} ${DIM}· trusted mode${N}"
    fi
    echo "  ${B}ports${N}     ${DIM}3000 3001 5173 4000 8080 → http://localhost:<port> on your Mac${N}"
  fi
  echo "  ${B}claude${N}    ${CLAUDE_STATE}"
  hr
  if [ "$mode" = sbx ]; then
    echo "  ${DIM}'exit' leaves — the microVM is KEPT (reused next spin) · new: airlock sbx --fresh · destroy: airlock sbx down${N}"
  else
    echo "  ${DIM}type 'exit' to leave — the container is destroyed (fresh next spin)${N}"
  fi
  echo ""
}

# Find the running sandbox container (untrusted or dev), excluding the proxy.
running_sandbox() {
  docker ps --format '{{.ID}} {{.Names}}' \
    | grep -E 'airlock-(untrusted|dev)-run' | awk '{print $1}' | head -1
}

# Proxy log: live container if running, else the saved last-session log.
proxy_log() {
  if docker ps --format '{{.Names}}' | grep -q '^airlock-proxy$'; then
    docker logs airlock-proxy 2>&1
  elif [ -f "$DIR/.logs/proxy-last.log" ]; then
    cat "$DIR/.logs/proxy-last.log"
  fi
}

# Tear down the proxy + networks, but ONLY if no other sandbox is still running
# (so a 2nd `airlock exec`/`run` terminal doesn't lose its network).
teardown_proxy_if_idle() {
  if docker ps --format '{{.Names}}' | grep -qE 'airlock-(untrusted|dev)-run'; then
    return 0   # another sandbox is live — leave the proxy up for it
  fi
  # Persist the proxy log so `airlock blocked` still works after teardown.
  if docker ps --format '{{.Names}}' | grep -q '^airlock-proxy$'; then
    mkdir -p "$DIR/.logs"
    docker logs airlock-proxy > "$DIR/.logs/proxy-last.log" 2>&1 || true
  fi
  echo "${DIM}› tearing down proxy + isolated network…${N}"
  dc --profile run down --remove-orphans >/dev/null 2>&1 || true
}

# ---- sbx (Docker microVM) integration -------------------------------------
# `airlock sbx` runs the project inside a Docker Sandbox: a microVM with its
# OWN kernel (hardware-enforced isolation, so a container escape can't reach the
# host), and we apply airlock's SAME egress whitelist via the sandbox's proxy.
# Escape-proof + exfil-proof. Requires `docker sandbox` (Docker Desktop 4.58+).

# Image used as the microVM template so airlock's tooling (node/pnpm/deploy CLIs)
# is present inside. Override with AIRLOCK_SBX_TEMPLATE= to use sbx's default,
# or AIRLOCK_SBX_TEMPLATE=some/image to use another.
SBX_TEMPLATE="${AIRLOCK_SBX_TEMPLATE-$SANDBOX_IMAGE}"

dsbx() { docker sandbox "$@"; }

sbx_require() {
  if ! docker sandbox version >/dev/null 2>&1; then
    echo "${R}✗ 'docker sandbox' not available.${N}"
    echo "  airlock sbx needs Docker Sandboxes (Docker Desktop 4.58+ or the sbx CLI)."
    echo "  Update Docker Desktop, or use ${G}airlock run${N} (container mode) instead."
    exit 1
  fi
}

# Stable per-project sandbox name (sbx allows [A-Za-z0-9._+-]).
sbx_name() {
  local base hash
  base="$(basename "$WORKSPACE" | tr -cs 'A-Za-z0-9._+-' '-' | sed 's/-*$//')"
  hash="$(printf '%s' "$WORKSPACE" | cksum | cut -d' ' -f1)"
  printf 'airlock-%s-%s' "${base:-ws}" "$hash"
}

sbx_exists() { docker sandbox ls 2>/dev/null | grep -qw "$1"; }

# Translate airlock's regex whitelist into `--allow-host` flags for the sbx
# proxy. *.foo.com -> foo.com (sbx matches the domain + its subdomains).
sbx_apply_whitelist() {
  local name="$1" d; local -a allow=()
  while IFS= read -r d; do
    [ -n "$d" ] && allow+=(--allow-host "$d")
  done < <(readable_whitelist | sed -E 's/^\*\.//' | sort -u)
  dsbx network proxy "$name" --policy deny "${allow[@]}" >/dev/null
}

print_help() {
  cat <<EOF
  ${B}airlock${N} — disposable hardened sandbox for running untrusted code & deploying

  ${B}USAGE${N}
    airlock <command> [args]

  ${B}ENTER A SANDBOX${N}
    ${G}run${N} [cmd]        🔒 untrusted code — no history, whitelist-only network
    ${Y}dev${N} [cmd]        ⚠  your own code — Claude login + full internet
    ${C}sbx${N} [cmd]        🧊 strongest — Docker microVM (own kernel) + whitelist
                     ${DIM}kept & reused by default · 'airlock sbx --fresh' new · 'airlock sbx down' destroy${N}
    exec [cmd]       open another terminal into the running sandbox

  ${B}NETWORK${N}
    allow <domain>   permit a domain in 'run' mode, then run: airlock rebuild
    blocked          list the URLs/hosts the proxy denied (not whitelisted)
    logs             watch what the proxy allows / blocks (live)

  ${B}LIFECYCLE${N}  ${DIM}(fresh start / destroy — works for every mode)${N}
    run / dev        throwaway: each spin is a fresh container (--rm), destroyed on exit
    sbx              kept & reused so login/installs persist; ${DIM}airlock sbx --fresh${N} = new box
    sbx down         destroy just this project's microVM
    down             stop & remove EVERYTHING — run/dev containers, proxy, all sbx microVMs

  ${B}MANAGE${N}
    status           what's running, and whether it's safe
    down             stop & remove the sandboxes (run/dev/sbx) + proxy
    build            build images
    rebuild          build images from scratch (no cache)

  ${B}INFO${N}
    help             this help   (also: --help, -h)

  ${B}EXAMPLES${N}  ${DIM}(by use case)${N}
    ${DIM}cd ~/some/oss && airlock run${N}        untrusted OSS — safe, light, throwaway
    ${DIM}cd ~/CodeBase/app && airlock dev${N}    your own code — full internet, your tools
    ${DIM}cd ~/malware && airlock sbx${N}         hostile code / agents — microVM, escape-proof
    ${DIM}airlock run npm test${N}                one-off command in a fresh box
    ${DIM}airlock sbx npm test${N}                one-off command in the kept microVM
    ${DIM}airlock sbx --fresh${N}                 wipe & rebuild this project's microVM
    ${DIM}airlock sbx down${N}                    destroy this project's microVM
    ${DIM}airlock allow files.example.com${N}     widen the whitelist (run/sbx)

  ${DIM}The folder you launch from becomes /workspace — the only host folder the
  sandbox sees. Bind dev servers to 0.0.0.0 to reach them at localhost on your Mac.${N}
EOF
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  run|shell)
    ensure_built
    set_workspace
    sync_claude_creds
    launch_banner run
    # When this sandbox shell exits (or Ctrl-C), stop the proxy too — unless
    # another sandbox terminal is still running. Keeps no internet-connected
    # container lingering once you're done.
    trap teardown_proxy_if_idle EXIT
    if [ "$#" -eq 0 ]; then
      dc --profile run run --rm --service-ports untrusted bash
    else
      dc --profile run run --rm --service-ports untrusted "$@"
    fi
    ;;

  dev)
    ensure_built
    set_workspace
    sync_claude_creds
    launch_banner dev
    if [ "$#" -eq 0 ]; then
      dc --profile dev run --rm --service-ports dev bash
    else
      dc --profile dev run --rm --service-ports dev "$@"
    fi
    ;;

  exec)
    cid="$(running_sandbox || true)"
    if [ -z "${cid:-}" ]; then
      echo "✗ no running sandbox — start one first: airlock run   (or: airlock dev)"
      exit 1
    fi
    echo "› attaching to running sandbox $cid"
    if [ "$#" -eq 0 ]; then docker exec -it "$cid" bash; else docker exec -it "$cid" "$@"; fi
    ;;

  sbx)
    sbx_require
    set_workspace
    name="$(sbx_name)"

    # Subcommands / flags (KEEP by default; --fresh deletes the old one first).
    case "${1:-}" in
      down|rm)
        if sbx_exists "$name"; then
          echo "› removing microVM sandbox '$name'…"
          dsbx rm "$name" >/dev/null 2>&1 || true
          echo "› done"
        else
          echo "› no microVM for this project — nothing to remove"
        fi
        exit 0
        ;;
      --fresh|fresh|new)
        shift || true
        if sbx_exists "$name"; then
          echo "${DIM}› --fresh: deleting old microVM '$name'…${N}"
          dsbx rm "$name" >/dev/null 2>&1 || true
        fi
        ;;
    esac

    # Reuse the kept microVM if it exists; otherwise create one.
    if sbx_exists "$name"; then
      echo "${DIM}› reusing microVM '$name' — login + installs from last time persist${N}"
    else
      ensure_built            # the template reuses airlock's tooling image
      echo "${DIM}› creating microVM sandbox '$name'…${N}"
      if [ -n "$SBX_TEMPLATE" ]; then
        dsbx create --name "$name" --template "$SBX_TEMPLATE" shell "$WORKSPACE"
      else
        dsbx create --name "$name" shell "$WORKSPACE"
      fi
    fi
    echo "${DIM}› applying egress whitelist (default-deny)…${N}"
    sbx_apply_whitelist "$name"
    # Claude isn't auto-seeded (sbx mounts only the project) — but the box is
    # KEPT, so `/login` once inside and it persists across future spins.
    CLAUDE_STATE="${DIM}run /login once — it persists (sandbox is kept)${N}"
    launch_banner sbx
    # KEEP by default: no teardown on exit. New box: airlock sbx --fresh.
    # Destroy: airlock sbx down.
    if [ "$#" -eq 0 ]; then
      dsbx run "$name"
    elif [ -t 0 ]; then
      dsbx exec -it "$name" "$@"
    else
      dsbx exec -i "$name" "$@"   # piped/no-TTY: don't request a pseudo-TTY
    fi
    ;;

  allow)
    [ "$#" -ge 1 ] || { echo "usage: airlock allow <domain>   e.g. airlock allow example.com"; exit 1; }
    dom="$1"
    # Escape dots, anchor to end-of-host so subdomains of it match.
    printf '\\.%s$\n' "$(echo "$dom" | sed 's/^\*\.//; s/\./\\./g')" >> "$FILTER"
    echo "› added '$dom' to whitelist. Rebuild to apply:  airlock rebuild"
    ;;

  down)
    echo "› stopping sandbox + proxy…"
    dc --profile run --profile dev down --remove-orphans >/dev/null 2>&1 || true
    docker ps -a --format '{{.ID}} {{.Names}}' \
      | grep -E 'airlock-(untrusted|dev)-run' | awk '{print $1}' \
      | xargs -r docker rm -f >/dev/null 2>&1 || true
    # remove any airlock sbx microVMs too
    if docker sandbox version >/dev/null 2>&1; then
      docker sandbox ls 2>/dev/null | grep -oE 'airlock-[A-Za-z0-9._+-]+' | sort -u \
        | xargs -r -n1 docker sandbox rm >/dev/null 2>&1 || true
    fi
    echo "› done"
    ;;

  status)
    echo ""
    hr; echo "  ${B}airlock — status${N}"; hr
    echo ""

    # ---- images ----
    echo "  ${B}Images${N}"
    if image_exists "$SANDBOX_IMAGE"; then echo "    ${G}✓${N} sandbox   ${DIM}${SANDBOX_IMAGE}${N}"
    else echo "    ${R}✗${N} sandbox   ${DIM}${SANDBOX_IMAGE}${N}   ${Y}→ run: airlock build${N}"; fi
    if image_exists "$PROXY_IMAGE"; then echo "    ${G}✓${N} proxy     ${DIM}${PROXY_IMAGE}${N}"
    else echo "    ${R}✗${N} proxy     ${DIM}${PROXY_IMAGE}${N}   ${Y}→ run: airlock build${N}"; fi
    echo ""

    # ---- running ----
    echo "  ${B}Running now${N}"
    found=0
    while IFS=$'\t' read -r name st; do
      [ -z "$name" ] && continue
      found=1
      case "$name" in
        *untrusted*) echo "    🔒 ${G}SAFE${N}     ${name}  ${DIM}· untrusted · whitelist net · ${st}${N}" ;;
        *dev*)       echo "    ⚠  ${Y}TRUSTED${N}  ${name}  ${DIM}· full internet + history · ${st}${N}" ;;
        *proxy*)     echo "    🛡  ${C}proxy${N}    ${name}  ${DIM}· egress whitelist · ${st}${N}" ;;
        *)           echo "    • ${name}  ${DIM}· ${st}${N}" ;;
      esac
    done < <(docker ps --filter "name=airlock" --format '{{.Names}}\t{{.Status}}')
    [ "$found" = 0 ] && echo "    ${DIM}nothing running — sandboxes are disposable, this is normal${N}"
    echo ""

    # ---- modes ----
    echo "  ${B}Modes${N}"
    echo "    ${G}airlock run${N}   🔒 ${G}safe${N}     ${DIM}untrusted code · whitelist network · no history${N}"
    echo "    ${Y}airlock dev${N}   ⚠  ${Y}trusted${N}  ${DIM}your code · full internet · Claude history${N}"
    echo ""

    # ---- whitelist (readable) ----
    wl_count="$(readable_whitelist | wc -l | tr -d ' ')"
    echo "  ${B}Network whitelist${N}  ${DIM}· ${wl_count} domains reachable in 'run' mode; all others blocked${N}"
    printf '%s' "$C"
    readable_whitelist | awk '{printf "    %-26s", $0; if (NR%2==0) printf "\n"} END {if (NR%2) printf "\n"}'
    printf '%s' "$N"
    echo "    ${DIM}edit: airlock allow <domain>   ·   list lives in proxy/filter${N}"
    hr
    ;;

  blocked)
    if docker ps --format '{{.Names}}' | grep -q '^airlock-proxy$'; then src="live"; else src="last session"; fi
    echo ""
    hr; echo "  ${B}airlock — blocked egress${N}  ${DIM}· ${src}${N}"; hr
    blk="$(proxy_log | sed -nE 's/.*Proxying refused on filtered domain "([^"]+)".*/\1/p' | sort | uniq -c | sort -rn)"
    if [ -z "$blk" ]; then
      echo "    ${G}nothing blocked${N} ${DIM}— no denied requests recorded${N}"
    else
      echo "  ${B}Denied — not on the whitelist:${N}"
      printf '%s\n' "$blk" | while read -r n host; do
        printf "    ${R}✗${N} ${C}https://%s${N}%*s${DIM}%s×${N}\n" "$host" $(( 34 - ${#host} > 1 ? 34 - ${#host} : 1 )) "" "$n"
      done
      echo ""
      echo "    ${DIM}to permit one:${N} airlock allow <domain>   ${DIM}then${N} airlock rebuild"
    fi
    hr
    ;;
  build)   dc --profile run --profile dev build "$@" ;;
  rebuild) dc --profile run --profile dev build --no-cache "$@" ;;
  logs)    docker logs -f airlock-proxy ;;

  help|-h|--help) print_help ;;
  *) echo "unknown command: $cmd"; echo "try: airlock --help"; exit 1 ;;
esac
